# Database (bun:sqlite file path)
DATABASE_PATH=./data/praamipiletid.db

# better-auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated emails that get the admin role on first sign-in
ADMIN_EMAILS=

# Notifier backend (currently only "ntfy")
NOTIFIER=ntfy
NTFY_BASE_URL=https://ntfy.sh

# AES-256-GCM key for encrypting captured praamid.ee session tokens at rest.
# 32 bytes hex (64 chars). Generate with: bun run scripts/gen-cred-key.ts
PRAAMID_CRED_KEY=
