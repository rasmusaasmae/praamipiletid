# Database (Postgres connection string)
DATABASE_URL=postgres://ferry:ferry@localhost:5432/ferry

# Public base URL of the app (used by better-auth for OAuth callback URLs,
# and anywhere else that needs to construct absolute links).
APP_URL=http://localhost:3000

# better-auth
BETTER_AUTH_SECRET=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: {APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP for outbound notification email. Proton Mail submission requires
# a paid plan with a custom domain; generate an SMTP token in
# Settings → All settings → Mail → IMAP/SMTP → SMTP tokens.
SMTP_HOST=smtp.protonmail.ch
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# How often the poller checks praamid.ee event capacities, in ms.
# Default 15000.
POLL_INTERVAL_MS=15000

# AES-256-GCM key for encrypting captured praamid.ee session tokens at rest.
# 32 bytes hex (64 chars). Generate with: bun run scripts/gen-cred-key.ts
PRAAMID_CRED_KEY=

# Optional Discord webhook for warn+ alerts. If unset, logs only go to stdout.
# Create via Server Settings → Integrations → Webhooks.
DISCORD_WEBHOOK_URL=

# Optional override for pino log level (trace|debug|info|warn|error|fatal).
# Defaults: debug in dev, info in prod.
LOG_LEVEL=
